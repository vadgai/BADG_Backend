# =============================================================================
# VADG Backend Environment Variables Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values

# =============================================================================
# GEMINI API KEYS - Multiple Keys with Automatic Fallback
# =============================================================================
# The system supports up to 10 Gemini API keys for automatic fallback.
# If one key fails (rate limit, quota exceeded, etc.), the system will 
# automatically try the next key in sequence.
#
# You can add anywhere from 1 to 10 keys. The system will use them in order:
# Key 1 (primary) -> Key 2 (fallback) -> Key 3 -> ... -> Key 10
#
# Get your Gemini API keys from: https://makersuite.google.com/app/apikey
# =============================================================================

# Primary API Key (required)
GEMINI_API_KEY_1=your_primary_gemini_api_key_here

# Fallback API Keys (optional - add as many as you need, up to 10 total)
GEMINI_API_KEY_2=your_second_gemini_api_key_here
GEMINI_API_KEY_3=your_third_gemini_api_key_here
GEMINI_API_KEY_4=your_fourth_gemini_api_key_here
GEMINI_API_KEY_5=your_fifth_gemini_api_key_here
GEMINI_API_KEY_6=your_sixth_gemini_api_key_here
GEMINI_API_KEY_7=your_seventh_gemini_api_key_here
GEMINI_API_KEY_8=your_eighth_gemini_api_key_here
GEMINI_API_KEY_9=your_ninth_gemini_api_key_here
GEMINI_API_KEY_10=your_tenth_gemini_api_key_here

# Legacy API key variables (for backward compatibility)
# If you only have one key, you can use either GOOGLE_API_KEY or GEMINI_API_KEY
# These will be used as fallback if GEMINI_API_KEY_1 through GEMINI_API_KEY_10 are not set
# GOOGLE_API_KEY=your_legacy_api_key_here
# GEMINI_API_KEY=your_legacy_api_key_here

# =============================================================================
# DATABASE CONFIGURATION (MongoDB)
# =============================================================================
# Primary variable used by Backend/database/connection.py
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/vadg?retryWrites=true&w=majority&appName=Cluster0
MONGO_DB_NAME=vadg
# Legacy alias (also supported):
# MONGODB_URL=mongodb://localhost:27017/?directConnection=true
# MONGODB_DATABASE=vadg_db

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
# Set to 1 to enable verbose debug logging
VADG_DEBUG=0

# Server Configuration
HOST=0.0.0.0
PORT=8080

# =============================================================================
# SECURITY (Production) — REQUIRED. Admin auth fails closed if these are unset.
# =============================================================================
SECRET_KEY=your-secret-key-change-in-production-to-a-long-random-string

# Admin JWT signing secret (ADMIN_JWT_SECRET preferred; JWT_SECRET_KEY also accepted).
# There is NO insecure default — if unset, admin login/token verification is denied.
ADMIN_JWT_SECRET=change-me-to-a-long-random-string
JWT_SECRET_KEY=change-me-to-a-long-random-string
ADMIN_JWT_EXPIRY_HOURS=24

# Admin login credentials (previously hardcoded in source — now env-only).
ADMIN_EMAIL=admin@example.com
# Provide ONE of the following. ADMIN_PASSWORD_HASH (bcrypt) is preferred over plaintext.
# Generate a hash: python -c "from passlib.hash import bcrypt; print(bcrypt.hash('yourpassword'))"
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD=change-me

# In-memory session store bounds (optional; defaults shown).
SESSION_TIMEOUT=3600
MAX_SESSIONS=1000

# =============================================================================
# USER AUTHENTICATION (auth_users collection) — /api/auth/*
# =============================================================================
# Access/refresh tokens are signed with JWT_SECRET_KEY / ADMIN_JWT_SECRET above.
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
VERIFY_TOKEN_EXPIRE_HOURS=48
RESET_TOKEN_EXPIRE_MINUTES=30
# If true, users must verify their email before they can sign in.
REQUIRE_EMAIL_VERIFICATION=true

# Permanent admin account (seeded on startup; cannot be demoted/deactivated).
PERMANENT_ADMIN_EMAIL=m87.krishna@gmail.com
PERMANENT_ADMIN_NAME=VADG Admin

# Seed a handful of demo users on startup (dev/demo only). Also available via
# `python add_dummy_users.py`. Demo users share DUMMY_USER_PASSWORD.
SEED_DUMMY_USERS=false
DUMMY_USER_PASSWORD=Test@1234
# Password used ONLY when first seeding the permanent admin. If unset, a random
# password is generated and the admin must use "forgot password" to set one.
PERMANENT_ADMIN_PASSWORD=

# =============================================================================
# EMAIL / SMTP — verification, password reset, welcome & system emails
# =============================================================================
# Gmail SMTP with an App Password (not the account password). Create one at
# https://myaccount.google.com/apppasswords for vadg.office@gmail.com.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=vadg.office@gmail.com
SMTP_PASSWORD=your-gmail-app-password
MAIL_FROM=vadg.office@gmail.com
MAIL_FROM_NAME=VADG
SUPPORT_EMAIL=vadg.office@gmail.com
# Base URL of the frontend, used to build verification/reset links in emails.
FRONTEND_URL=http://localhost:5173

# =============================================================================
# BILLING / PRICING (credit-based report limits) — /api/billing/*
# =============================================================================
# Free diagnosis reports every registered user gets per calendar day.
FREE_REPORTS_PER_DAY=1
# Pay-as-you-go price per extra report (whole rupees). Also the "payg" plan price.
PAY_PER_REPORT_PRICE_INR=29
# Default packs (₹399→15, ₹599→25) are seeded into the pricing_plans collection
# on startup and are editable from the admin dashboard.
#
# Payment gateway (OPTIONAL). Left blank → purchases run in MANUAL/DEV mode
# (order created + confirmed without an external charge). Set both to enable a
# real Razorpay integration once the gateway hooks in billing/payments.py are
# switched on.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Manual purchase flow: users submit a plan request + payment reference, and an
# admin approves it after verifying the payment. These control what the user
# sees and where admin alerts go.
ADMIN_NOTIFY_EMAIL=vadg.office@gmail.com
PAYMENT_UPI_ID=vadg@upi
PAYMENT_PAYEE_NAME=VADG
PAYMENT_INSTRUCTIONS=Pay the plan amount to the UPI ID above, then submit your UPI/UTR reference below. Report credits are activated after our team verifies the payment (usually within a few hours).

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Add your frontend URLs here, separated by commas
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://vadg.in,https://www.vadg.in

# =============================================================================
# TRANSLATION SERVICE (IndicTrans2 200M Microservice)
# =============================================================================
# URL of the translation-service microservice
TRANSLATION_SERVICE_URL=http://localhost:8080

# API key for authenticating with the translation service
TRANSLATION_SERVICE_API_KEY=your_translation_service_api_key_here

# Request timeout in seconds (default: 15)
TRANSLATION_SERVICE_TIMEOUT=15

# =============================================================================
# NOTES
# =============================================================================
# 1. Never commit your actual .env file to version control
# 2. Keep your API keys secure and rotate them regularly
# 3. Each Gemini API key has usage limits - using multiple keys helps distribute load
# 4. The system will automatically try the next key if one fails
# 5. Monitor your API key usage at: https://console.cloud.google.com/
# 6. Translation service uses IndicTrans2 200M for cost-efficient translations

